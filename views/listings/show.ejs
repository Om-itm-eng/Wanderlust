<% layout('layouts/boilerplate') -%>
<!-- below script is used to pass the map api key from env file to the map.js file which is included at the end of this file -->
<script>
    const mapAPIKey = '<%=process.env.MAP_API_KEY %>';
    const userLocation = '<%=user.location%>';
</script>

<br>
<div class="row">
    <div class="card col-10 offset-1">
        <h2><%=user.title%></h2>
        <img src="<%=user.image.url%>" class="card-img-top" id="show-img" alt="NO image found">
        <div class="card-body">
            <p class="card-text">
                    <b>Posted By :</b> 
                    <i><%=user.owner.username%></i>
            </p>
            <p class="card-text"><%=user.description%></p>
            <div><b>&#8377;<%=user.price%></b></div>
            <div><b><%=user.location%></b></div>
            <div><b><%=user.country%></b></div>
            <% if(currUser && currUser._id.equals(user.owner._id)) { %>
                <div class="mt-3 btns " >
                    <a href="/listings/<%=user._id%>/edit" class="btn btn-success col-lg-1" >Edit</a>
                    <form action="/listings/<%=user._id%>?_method=DELETE" method="post"><button class="btn btn-danger col offset-1">Delete</button></form>
                </div>
            <% } %> 
        </div>
        <hr> 
        <% if(currUser && !currUser._id.equals(user.owner._id)) { %>
            <div class="mt-2 ">
                <h4>Post Review</h4>
                <form action="/listings/<%=user.id%>/reviews" method="post">
                    <!-- stars-style -->
                    <fieldset class="starability-basic">
                        <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="rating" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="rating" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="rating" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="rating" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="rating" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                    <!-- comment -->
                    <div class="mt-3">
                        <label for="comment" class="form-label">Comment</label>
                        <textarea name="comment" id="comment" cols="30" rows="5" class="form-control"></textarea>
                    </div>
                    <button class="btn btn-primary mt-3 ">Send</button>
                </form>
            </div>
            <hr>
        <% } %>
        
        <div class="mt-2 row">
            <% if(user.reviews.length > 0) {%>
                <h4>All Reviews</h4>
            <% } %>
            <% for(let r of user.reviews) { %>
                <div class="card review col-lg-5 ms-3 mb-2 mt-3">
                    <div class="card-body">
                        <h3><%= r.author.username %></h3>
                        <p class="starability-result" data-rating= <%=r.rating%>>
                            Rated: 3 stars
                        </p>
                        <p class="card-title"><%=r.comment%></p>
                        <% if(currUser && currUser._id.equals(r.author._id)) { %>
                            <form action="/listings/<%=user._id%>/reviews/<%=r._id%>?_method=DELETE" method="post">
                                <button class="btn btn-dark">Delete</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }%>
        </div>

        <h4>Location </h4>
        <!-- we include map using cdn link -->
        <div id='map' style= 'width: 60vw; height: 350px;'></div>
    </div>
    <script src="/js/map.js"></script>
</div>